# Runtime. Production values are shown for the two public email origins because
# lifecycle email sending fails closed unless they are valid HTTPS URLs.
APP_URL=http://localhost:3001/backoffice
APP_ENV=development
CUSTOMER_APP_URL=https://www.pixbrik.com
PUBLIC_EMAIL_APP_URL=https://www.pixbrik.com/backoffice

# PostgreSQL (server only). Each URL uses the dedicated role named in the
# database-security runbook; never point runtime code at the migrator.
ADMIN_DATABASE_URL=postgresql://pixbrik_admin_runtime:password@host:5432/pixbrik?sslmode=require
CUSTOMER_DATABASE_URL=postgresql://pixbrik_customer_runtime:password@host:5432/pixbrik?sslmode=require
IDENTITY_DATABASE_URL=postgresql://pixbrik_identity_runtime:password@host:5432/pixbrik?sslmode=require
SERVICE_DATABASE_URL=postgresql://pixbrik_service_runtime:password@host:5432/pixbrik?sslmode=require

# OPERATOR SHELL ONLY. Privileged migration role on the provider's direct,
# non-pooler endpoint. Do not add this variable to any Vercel Project
# Environment or .env.local; set it only in the controlled process that runs
# db:migrate, then remove it.
# MIGRATION_DATABASE_URL=postgresql://pixbrik_migrator:password@host:5432/pixbrik?sslmode=require

# Authentication. Supported modes: disabled, development, password,
# trusted-gateway, clerk.
# Use development only locally. A trusted gateway must strip client identity headers,
# verify the real provider session, and inject the shared gateway secret server-side.
# Clerk must use a separate, invite-only staff application/instance. Do not reuse
# buyer-app keys. Require verified email and the setup-mfa session task in Clerk.
AUTH_MODE=disabled
DEV_ADMIN_EMAIL=sam@benisty.ca
# Built-in password mode. Generate two different 32-byte keys and keep the
# `v1:` prefix. Never commit the values or reuse one key for both purposes.
AUTH_PASSWORD_PEPPER=
# Optional during rotation only: up to four comma-separated older versioned
# peppers. Every version must be lower than AUTH_PASSWORD_PEPPER. Remove an old
# key only after all credentials have been rehashed with the current version.
AUTH_PASSWORD_PEPPER_PREVIOUS=
AUTH_SESSION_HMAC_KEY=
AUTH_GATEWAY_SECRET=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/backoffice/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/backoffice
NEXT_PUBLIC_CLERK_PROXY_URL=/backoffice/__clerk

# Stripe test environment (never commit keys; use your own Stripe test account values)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend lifecycle email. Verify the sending domain and create the webhook before
# enabling any automation in Backoffice > Marketing.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_FROM_EMAIL=PixBrik <hello@pixbrik.com>
RESEND_REPLY_TO_EMAIL=hello@pixbrik.com
# Set true only after sender DNS, webhook delivery and a production smoke email
# have all been verified. Until then campaigns and automations stay locked.
EMAIL_DELIVERY_APPROVED=false
# Capability flags remain false until their customer-facing destinations work.
CUSTOMER_PORTAL_EMAIL_LINKS_READY=false
CHECKOUT_RECOVERY_EMAIL_READY=false
CUSTOMER_APP_EMAIL_LINKS_READY=false

# Private asset storage
BLOB_READ_WRITE_TOKEN=

# Daily EUR FX source. Token is optional for a public reference-rate source.
FX_PROVIDER_URL=
FX_PROVIDER_TOKEN=
FX_STALE_AFTER_HOURS=48

# Scheduled/internal jobs. Use an independently generated value with at least
# 32 random bytes. Vercel sends it as an Authorization bearer token.
CRON_SECRET=
