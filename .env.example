# Copy to apps/mobile/.env.local and fill real values. NEVER commit real keys.
#
# Tripo image-to-3D API key (server-side only — held by the Vercel serverless
# proxy so it is never shipped in the browser bundle).
# Get one at https://platform.tripo3d.ai — the account needs purchased credits.
TRIPO_API_KEY=tsk_your_key_here

# Meshy is the preferred server-side image/multiview-to-3D provider when both
# providers are configured. Keep this secret on the Vercel function only.
MESHY_API_KEY=msy_your_private_key_here

# Public flag (safe to expose) — enables the "True 3D from your photo" UI path.
EXPO_PUBLIC_TRIPO_ENABLED=1

# Tripo model version (cost/quality trade-off). The quality-first default uses
# current v3.1 detailed geometry/textures; P1 is supported as a premium option.
TRIPO_MODEL_VERSION=v3.1-20260211
# Optional source-mesh ceiling before PixBrik's catalog voxelizer (default 100000).
TRIPO_FACE_LIMIT=100000

# Paid 3D generation circuit breakers. Production fails closed unless enabled.
# Also configure distributed rate limits for /api/{meshy,tripo}/submit in the
# Vercel Firewall; these in-app limits are defense in depth for warm functions.
GENERATION_API_ENABLED=0
GENERATION_ALLOWED_ORIGINS=https://pixbrik.com,https://www.pixbrik.com
GENERATION_IP_HOURLY_LIMIT=6
GENERATION_DAILY_TASK_LIMIT=100

# Smart background isolation is default-off on both sides. The public flag
# only exposes the UI; the separate server flag authorizes paid provider calls.
# Provider secrets stay server-side and must never use EXPO_PUBLIC_ names.
EXPO_PUBLIC_BACKGROUND_REMOVAL_ENABLED=0
BACKGROUND_REMOVAL_API_ENABLED=0
BACKGROUND_REMOVAL_ALLOWED_ORIGINS=https://pixbrik.com,https://www.pixbrik.com
BACKGROUND_REMOVAL_IP_HOURLY_LIMIT=10
BACKGROUND_REMOVAL_DAILY_PROVIDER_LIMIT=200

# Optional preference when both provider keys are configured: photoroom | removebg.
# If the preferred key is absent, the proxy uses the other configured provider.
BACKGROUND_REMOVAL_PROVIDER=photoroom
PHOTOROOM_API_KEY=your_photoroom_server_key_here
REMOVE_BG_API_KEY=your_remove_bg_server_key_here

# Durable QR build guides (server-side only). Create/connect a Vercel Blob
# store for the mobile project; Vercel injects this read/write token. Published
# JSON is public but addressed by an unguessable 128-bit id and contains only
# the frozen build/manual — never customer details or source mesh URLs.
# Add a Vercel Firewall rate-limit rule for POST /api/guides/share before launch
# and schedule deletion of expired guide blobs to cap anonymous storage usage.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here

# Canonical public web origin placed in QR links. Set this explicitly in
# production so forwarded Host headers can never choose the QR destination.
GUIDE_SHARE_APP_URL=https://pixbrik.com

# The same canonical origin is compiled into native Expo builds so the Share
# button can reach the server API and hand off the web guide URL.
EXPO_PUBLIC_GUIDE_APP_URL=https://pixbrik.com

# Optional retention metadata for published guides: integer days, 1–90.
# Readers reject expired snapshots. Configure scheduled Blob deletion as part
# of production retention; public Blob objects are bearer links. Default: 30.
GUIDE_SHARE_TTL_DAYS=30

# Branded contact email (server-side only). Verify pixbrik.com in Resend before
# using hello@pixbrik.com as the sender. Add the API key to Vercel as a secret;
# never prefix it with EXPO_PUBLIC_.
RESEND_API_KEY=re_your_private_resend_key
RESEND_FROM_EMAIL=PixBrik <hello@pixbrik.com>
CONTACT_RECIPIENT_EMAIL=hello@pixbrik.com
CONTACT_ALLOWED_ORIGINS=https://pixbrik.com,https://www.pixbrik.com
PIXBRIK_APP_URL=https://pixbrik.com

# Public canonical origin used by native Expo builds for same-backend APIs.
EXPO_PUBLIC_APP_URL=https://pixbrik.com

# Buyer identity (safe public Clerk key). Configure the matching secret only in
# Clerk/Vercel; the Expo buyer app must never receive CLERK_SECRET_KEY.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_or_live_value

# Legal drafts are deliberately hidden in production. Enable only in an
# isolated Preview environment for counsel/owner review.
EXPO_PUBLIC_DEPLOYMENT_ENV=production
EXPO_PUBLIC_LEGAL_DRAFTS_ENABLED=0
